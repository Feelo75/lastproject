generator client {
  provider = "prisma-client-id"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Entry {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  message     String
  mood        String   // เช่น 😊, 😢, 😡
  weatherCity String   // ภูเก็ต
  weatherTemp Float    // 28.5
  weatherDesc String   // ฝนตก
}