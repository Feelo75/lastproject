// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Entry {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  message      String
  mood         String
  weatherCity  String
  weatherTemp  Float
  weatherDesc  String
}